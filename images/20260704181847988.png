<script>
    fetch(`https://api.paritydeals.com/api/v1/deals/discount/?url=${window.location.href}`)
    .then(response => response.json())
    .then(data => {
        const { country, countryFlag, couponCode, discountPercentage, isVpn } = data;

        // Create parity banner if eligible
        if (!isVpn && typeof couponCode !== 'undefined') {
            const container = document.getElementById('parity-banner-container-lesson');
            if (container) {
                const hasAccess = container.getAttribute('data-has-access') === 'true';
                const formattedCountry = `<b>${country} ${countryFlag}</b>`;
                const formattedDiscountPercentage = parseFloat(discountPercentage).toFixed(0);

                let bannerMessage;
                if (hasAccess) {
                    // User has access to this content (free article)
                    bannerMessage = `Hey! Enjoy the free article. It looks like you are from ${formattedCountry}. So whenever you are ready, join by visiting this <b><u><a href="${couponCode}">membership page</a></u></b> for relief pricing of <b>${formattedDiscountPercentage}%</b> off on your full access, FOREVER.`;
                } else {
                    // User does not have access (member-only content)
                    bannerMessage = `Hey! This is a member-only post. But it looks like you are from ${formattedCountry}. Join today by visiting this <b><u><a href="${couponCode}">membership page</a></u></b> for relief pricing of <b>${formattedDiscountPercentage}%</b> off on your full access, FOREVER.`;
                }

                container.innerHTML = bannerMessage;
            }
        } else {
            // Hide the banner container if not eligible
            const bannerCard = document.querySelector('.kg-callout-card-purple');
            const bannerHr = bannerCard ? bannerCard.nextElementSibling : null;
            if (bannerCard) bannerCard.style.display = 'none';
            if (bannerHr && bannerHr.tagName === 'HR') bannerHr.style.display = 'none';
        }
    })
    .catch(error => {
        console.error('Error fetching parity deals:', error);
        // Hide the banner on error
        const bannerCard = document.querySelector('.kg-callout-card-purple');
        const bannerHr = bannerCard ? bannerCard.nextElementSibling : null;
        if (bannerCard) bannerCard.style.display = 'none';
        if (bannerHr && bannerHr.tagName === 'HR') bannerHr.style.display = 'none';
    });
</script>

    
